# Maynooth Homestead — Digital Twin Environment
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Ecowitt ──────────────────────────────────────────────────────────────────
# 1. Log into app.ecowitt.net
# 2. Account → API Keys → "Create Application Key" → paste below
ECOWITT_APPLICATION_KEY=YOUR_APPLICATION_KEY_HERE

# Your personal API key (already in Gardening/.env)
ECOWITT_API_KEY=713783f4-645e-4b35-9eed-5a03069ddc32

# GW3000 MAC address (find in Ecowitt app: Device → Settings → About)
# Format: AA:BB:CC:DD:EE:FF
ECOWITT_DEVICE_MAC=YOUR_GW3000_MAC_HERE

# ── InfluxDB ─────────────────────────────────────────────────────────────────
INFLUX_USER=admin
INFLUX_PASSWORD=maynooth_gh_2026
INFLUX_ORG=maynooth
INFLUX_BUCKET=greenhouse
INFLUX_TOKEN=maynooth-digital-twin-super-secret-token-2026

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=maynooth_gh_2026

# ── Poller ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
